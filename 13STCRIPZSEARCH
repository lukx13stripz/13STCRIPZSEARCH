local function updateActionButton(playerName)
    ActionBtn.Text = "13ST CRIPZ SEARCH " .. string.upper(playerName)
end

-- Function to create player row
local function createPlayerRow(player)
    if player == LocalPlayer then return end
    
    local Row = Instance.new("TextButton")
    Row.Name = player.Name
    Row.Size = UDim2.new(1, -6, 0, 35)
    Row.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Row.BorderSizePixel = 0
    Row.Text = "     " .. player.Name
    Row.TextColor3 = Color3.fromRGB(200, 200, 200)
    Row.Font = Enum.Font.SourceSans
    Row.TextSize = 14
    Row.TextXAlignment = Enum.TextXAlignment.Left
    Row.Parent = PlayerList
    
    local RowCorner = Instance.new("UICorner")
    RowCorner.CornerRadius = UDim.new(0, 6)
    RowCorner.Parent = Row
    
    local Icon = Instance.new("ImageLabel")
    Icon.Size = UDim2.new(0, 14, 0, 14)
    Icon.Position = UDim2.new(0, 8, 0, 10)
    Icon.BackgroundTransparency = 1
    Icon.Image = "rbxassetid://11419714316"
    Icon.ImageColor3 = Color3.fromRGB(0, 120, 255)
    Icon.Parent = Row

    Row.MouseButton1Click:Connect(function()
        for _, child in pairs(PlayerList:GetChildren()) do
            if child:IsA("TextButton") then
                child.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            end
        end
        Row.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
        selectedPlayer = player
        updateActionButton(player.Name)
    end)
    
    PlayerList.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
end

local function refreshList()
    for _, child in pairs(PlayerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in pairs(Players:GetPlayers()) do
        createPlayerRow(player)
    end
end

Players.PlayerAdded:Connect(refreshList)
Players.PlayerRemoving:Connect(function(player)
    if selectedPlayer == player then
        selectedPlayer = nil
        ActionBtn.Text = "SELECT A PLAYER"
    end
    refreshList()
end)

refreshList()

-- Hooking into the game's built-in SearchGui items for Confiscation
local function hookInventoryItems(searchGuiInstance, targetPlayer)
    -- Nag-aabang ng mga buttons o items na lilitaw sa loob ng SearchGui ng laro
    for _, item in pairs(searchGuiInstance:GetDescendants()) do
        -- Karaniwang TextButton o ImageButton ang mga slots sa imbentaryo
        if item:IsA("TextButton") or item:IsA("ImageButton") then
            item.MouseButton1Click:Connect(function()
                -- Kung pinindot mo ang item sa nakabukas na SearchGui, ipapadala nito ang request sa server
                if ConfiscateEvent and targetPlayer then
                    -- I-fire ang event kasama ang target player at ang pangalan ng item na pinindot mo
                    ConfiscateEvent:FireServer(targetPlayer, item.Name)
                    print("13ST Network: Sent confiscate request for item: " .. item.Name .. " from " .. targetPlayer.Name)
                end
            end)
        end
    end
end

-- MAIN TRIGGER
ActionBtn.MouseButton1Click:Connect(function()
    if selectedPlayer then
        local SearchGui = PlayerGui:FindFirstChild("SearchGui")
        
        if SearchGui then
            if SearchGui:IsA("ScreenGui") then
                SearchGui.Enabled = true
            end
            
            for _, child in pairs(SearchGui:GetChildren()) do
                if child:IsA("Frame") or child:IsA("ScrollingFrame") then
                    child.Visible = true
                end
            end
            
            -- I-setup ang click detection sa mga gamit na ipapakita ng SearchGui ng laro
            hookInventoryItems(SearchGui, selectedPlayer)
            print("13ST Network: Inventory links attached to SearchGui.")
        else
            warn("13ST Network: 'SearchGui' not found inside PlayerGui!")
        end
        
        -- I-fire ang Search Remote para i-load ng server ang mga gamit ng player papunta sa SearchGui mo
        if SearchEvent then
            SearchEvent:FireServer(selectedPlayer)
        end
        
    else
        ActionBtn.Text = "CHOOSE A PLAYER FIRST!"
        task.wait(1)
        if selectedPlayer then updateActionButton(selectedPlayer.Name) else ActionBtn.Text = "SELECT A PLAYER" end
    end
end)
